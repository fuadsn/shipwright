# OpenAI
OPENAI_API_KEY=

# Slack OAuth app settings
# Create these at https://api.slack.com/apps -> Your app -> Basic Information.
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=
# Slack OAuth redirect URLs should be HTTPS. Use ngrok/Cloudflare Tunnel for local dev.
SLACK_REDIRECT_URI=https://your-public-dev-url.example.com/api/slack/oauth/callback

# Optional local-dev fallback. Prefer the in-app Connect Slack OAuth flow.
# SLACK_BOT_TOKEN=
# SLACK_CHANNEL_ID=

# Local servers
PORT=8787
CLIENT_ORIGIN=http://localhost:5173
CODEX_TIMEOUT_MS=600000

# Murphy access profiles
# Murphy chooses per-task between prod (read-only), staging (read-write), and free.
# These paths are the search roots Codex uses under each profile.
MURPHY_PROD_PATH=/absolute/path/to/your/prod-repo
MURPHY_STAGING_PATH=/absolute/path/to/your/staging-repo

# Optional defaults:
#   MURPHY_PROFILE=prod | staging | free   # the default profile when one isn't named
#   MURPHY_SEARCH_ROOTS=/path/one,/path/two # roots for the "free" profile
#   MURPHY_PROD_LABEL / MURPHY_STAGING_LABEL / MURPHY_FREE_LABEL  # display labels
